<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Background -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/bg_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#DD0D0D0F" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Toolbar -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/transparent"
                app:title="Settings"
                app:titleTextColor="@color/text_primary" />

            <!-- Settings categories (shown when no sub-fragment loaded) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_categories"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_java" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_renderer" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_controls" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_theme" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_account" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_performance" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_download" />
                    <include layout="@layout/item_settings_category"
                        android:id="@+id/category_about" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Fragment container for sub-settings pages -->
            <FrameLayout
                android:id="@+id/settings_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>
</LinearLayout>
