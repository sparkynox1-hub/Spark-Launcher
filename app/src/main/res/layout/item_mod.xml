<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    style="@style/Widget.Spark.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Mod Icon -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_mod_icon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Rounded.12"
            tools:src="@drawable/ic_mod_placeholder" />

        <!-- Source badge -->
        <TextView
            android:id="@+id/tv_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="-52dp"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textSize="9sp"
            android:textColor="@color/white"
            android:fontFamily="@font/nunito_bold"
            tools:text="MODRINTH" />

        <View
            android:layout_width="0dp"
            android:layout_height="8dp" />

        <!-- Mod name -->
        <TextView
            android:id="@+id/tv_mod_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="@font/nunito_bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Sodium" />

        <!-- Author -->
        <TextView
            android:id="@+id/tv_mod_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="CaffeineMC" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_mod_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="A modern rendering engine for Minecraft" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_download_small"
                android:tint="@color/text_secondary"
                android:contentDescription="Downloads" />

            <TextView
                android:id="@+id/tv_downloads"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                tools:text="12.4M" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_download"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Get"
                android:textSize="11sp"
                style="@style/Widget.Spark.Button.Primary"
                app:iconSize="14dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
